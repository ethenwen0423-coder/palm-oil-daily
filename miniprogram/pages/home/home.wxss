.hero { background: linear-gradient(145deg, #072e2a, #0c5a4f); color: #fff; padding: 62rpx 32rpx 40rpx; }
.brand-kicker { color: #d8b45e; font-size: 22rpx; letter-spacing: 5rpx; }
.brand-title { font-family: Georgia, serif; font-size: 54rpx; font-weight: 700; margin-top: 8rpx; }
.brand-subtitle { color: #b8cec8; margin-top: 8rpx; }
.view-card { background: rgba(255,255,255,.08); border: 1rpx solid rgba(255,255,255,.18); border-radius: 18rpx; margin-top: 38rpx; padding: 28rpx; }
.view-label { color: #d8b45e; display: flex; justify-content: space-between; font-size: 23rpx; }
.view-call { font-family: "Songti SC", serif; font-size: 36rpx; font-weight: 700; line-height: 1.45; margin: 18rpx 0; }
.view-point { color: #d7e4e0; font-size: 25rpx; margin-top: 8rpx; }
.updated { color: #91ada6; font-size: 21rpx; margin-top: 20rpx; }
.offline { background: #f2d27c; color: #4f3a08; border-radius: 8rpx; font-size: 22rpx; margin-top: 18rpx; padding: 10rpx 16rpx; text-align: center; }
.quick-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18rpx; }
.quick-grid button { margin: 0; }
.report-list { overflow: hidden; }
.report-row { display: flex; align-items: center; border-bottom: 1rpx solid #e7e0d2; padding: 24rpx; }
.report-row:last-child { border-bottom: 0; }
.report-kind { background: #e8f1ed; border-radius: 7rpx; color: #0e6b5c; flex: none; font-size: 21rpx; padding: 7rpx 10rpx; }
.report-main { flex: 1; min-width: 0; padding: 0 20rpx; }
.report-title { font-weight: 700; }
.report-headline { color: #6d756f; font-size: 23rpx; margin-top: 7rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.arrow { color: #9ca29e; font-size: 42rpx; }
.empty-row { padding: 40rpx; text-align: center; }
.disclaimer { color: #8a8f8c; font-size: 21rpx; padding: 54rpx 0 20rpx; text-align: center; }
