.offline { background: #f4dda1; border-radius: 10rpx; color: #5a4208; font-size: 22rpx; margin-bottom: 18rpx; padding: 12rpx; text-align: center; }
.tabs { display: flex; padding: 7rpx; }
.tab { border-radius: 12rpx; color: #707873; flex: 1; padding: 16rpx; text-align: center; }
.tab.active { background: #0e6b5c; color: #fff; font-weight: 700; }
.archive-heading { color: #7b837e; display: flex; font-size: 21rpx; justify-content: space-between; letter-spacing: 2rpx; margin: 36rpx 4rpx 16rpx; }
.report-card { margin-bottom: 20rpx; padding: 28rpx; }
.meta { color: #858c87; display: flex; font-size: 21rpx; justify-content: space-between; }
.meta text:first-child { color: #0e6b5c; font-weight: 700; }
.title { font-family: Georgia, "Songti SC", serif; font-size: 36rpx; font-weight: 700; margin-top: 20rpx; }
.headline { color: #59645f; line-height: 1.65; margin-top: 12rpx; }
.read { color: #0e6b5c; font-size: 24rpx; margin-top: 20rpx; }
.empty-state { padding: 100rpx 0; text-align: center; }
